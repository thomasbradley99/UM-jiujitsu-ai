# Copy these into the project-root .env.local (NOT into flywheel/).
# Both server.js and the Python loaders read from <repo_root>/.env.local.

# Gemini — used by spin.py to run the filter call.
GEMINI_API_KEY=your_gemini_key_here

# MuBit — used to fetch the active prompt, record outcomes, request optimizations.
# DO NOT put this in any VITE_* variable; it must stay server-side only.
MUBIT_API_KEY=mbt_<instance>_<key_id>_<secret>
