# Default: outputs/ contents are scratch, never committed.
# Re-include only the 4-iteration handtuned arc that backs the
# hackathon submission. Everything else regenerates on `flywheel.cli loop`.

outputs/*
!outputs/arc_report_handtuned.html
!outputs/loop_arc_handtuned.json

!outputs/runs/
outputs/runs/*
!outputs/runs/verify:video/
outputs/runs/verify:video/*
!outputs/runs/verify:video/pv-ac5575b2-da74-46ed-93c0-af646accf89b/
!outputs/runs/verify:video/pv-b535d177-bf2c-4659-a784-75ee44ab6fd8/
!outputs/runs/verify:video/pv-853f6c04-aee7-4b70-964e-7db81f69da6a/
!outputs/runs/verify:video/pv-377be9c6-d965-4e43-9511-43ab10ecd725/
outputs/runs/verify:video/*/profile_frames/

# Compiled / cache
__pycache__/
*.pyc
report.html
